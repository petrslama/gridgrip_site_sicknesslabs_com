<section class="o_comparison_table grid-sm"
	{{#if section_id}}
	 id="{{section_id}}"
	{{/if}}>
	<div class="col-12">
		{{> m_section_title }}
	</div>
	{{#each columns}}
	<div class="col-6">
		{{> a_h3 }}
		<ul>
			{{#each items}}
			<li>{{{this}}}</li>
			{{/each}}
		</ul>
	</div>
	{{/each}}
</section>
