<section class="o_letters"
	{{#if section_id}}
	 id="{{section_id}}"
	{{/if}}>
	<div class="grid">
		<div class="col-12">
			{{> m_section_title }}
		</div>
		{{#each items}}
		<div class="item col-6{{#if text_only}} item--summary{{/if}}">
			{{> a_eyebrow }}
			{{> a_h3 }}
			{{> a_description }}
			{{#unless text_only}}
			<div class="score-buttons">
				<button class="score-btn" data-val="3" aria-pressed="false">{{../label_1}}</button>
				<button class="score-btn" data-val="2" aria-pressed="false">{{../label_2}}</button>
				<button class="score-btn" data-val="1" aria-pressed="false">{{../label_3}}</button>
			</div>
			{{/unless}}
		</div>
		{{/each}}
	</div>
	<div class="score-panel"
		 data-summary-incomplete="{{summary_incomplete}}"
		 data-verdict-knockout="{{verdict_knockout}}"
		 data-verdict-perfect="{{verdict_perfect}}"
		 data-verdict-solid="{{verdict_solid}}"
		 data-verdict-weak="{{verdict_weak}}"
		 data-verdict-stop="{{verdict_stop}}">
		<div class="container">
			<div class="score-header">
				<h3 class="a_h3">{{summary_title}}</h3>
				<span class="score-total"></span>
			</div>
			<div class="score-bars"></div>
			<p class="score-verdict">{{summary_incomplete}}</p>
		</div>
	</div>
</section>
