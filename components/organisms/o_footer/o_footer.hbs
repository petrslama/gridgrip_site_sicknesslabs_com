<section class="o_footer grid">
	{{#if brand}}
	<div class="col-3 brand-column">
		<div class="logo">
			{{> a_image a_image=brand.a_image }}
			<span class="brand-name">SicknessLabs</span>
		</div>
		{{> a_description a_description=brand.a_description }}
	</div>
	{{/if}}
	{{#each columns}}
	<div class="col-3">
		{{> a_h3 }}
		{{#if links}}
		<ul class="nav-list">
			{{#each links}}
			<li class="nav-item"><a href="{{href}}">{{label}}</a></li>
			{{/each}}
		</ul>
		{{/if}}
	</div>
	{{/each}}
</section>
