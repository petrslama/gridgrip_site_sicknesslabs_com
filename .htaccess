RewriteEngine On
RewriteBase /

# ---------------------------------------------------------------
# 301 Redirects (3 rules, order matters)
# If Cloudflare "Always Use HTTPS" is ON, remove rules 1 + 2
# and keep only rule 3 (non-www -> www) + trailing slash
# ---------------------------------------------------------------

# 1) HTTP + non-www -> HTTPS www (single hop)
RewriteCond %{HTTP_HOST} !^localhost$ [NC]
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2) HTTP -> HTTPS (www already present)
RewriteCond %{HTTP_HOST} !^localhost$ [NC]
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3) non-www -> www (HTTPS already present)
RewriteCond %{HTTP_HOST} !^localhost$ [NC]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 4) Remove trailing slash (except root /)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [L,R=301]

# Cache: assets (long), HTML (short)
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|css|js|woff2|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

<FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
</FilesMatch>

# Favicon
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^favicon\.ico$ assets/icons/favicon.ico [L]

# RFC 9116: /.well-known/security.txt -> security.txt
RewriteRule ^\.well-known/security\.txt$ security.txt [L]

# CSS cache busting: style.min.TIMESTAMP.css -> style.min.css
RewriteRule ^html/style\.min\.\d+\.css$ html/style.min.css [L]

# Root: / -> html/home.html
RewriteRule ^$ html/home.html [L]

# Existing files/directories - pass through
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Pages: /about -> html/about.html
RewriteRule ^([^/]+)/?$ html/$1.html [L]

# Nested pages: /blog/article -> html/blog/article.html
RewriteRule ^(.+?)/?$ html/$1.html [L]

# 404
ErrorDocument 404 /html/404.html

